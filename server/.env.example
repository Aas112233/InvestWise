# BACKEND - Environment Variables Template
# Copy this file to .env and configure
# ===========================================

# Server Configuration (required)
NODE_ENV=development
PORT=5000

# MongoDB Connection (required)
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/investwise

# MongoDB Atlas (example):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/investwise

# JWT Secret (required)
# Generate a strong random string:
# openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration (required)
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# External Services API Keys (BACKEND ONLY!)
# NEVER expose these to frontend
# ===========================================

# LongCat AI API Key (for AI Strategist features)
# Get your API key from: https://longcat.chat/platform
LONGCAT_API_KEY=

# IPInfo Token (for IP geolocation)
# Get from: https://ipinfo.io/
# IPINFO_TOKEN=

# ===========================================
# OPTIONAL: Email Configuration
# Configure for password reset, notifications
# ===========================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
