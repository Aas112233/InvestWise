# ===========================================
# FRONTEND - Environment Variables Template
# Copy this file to .env and configure
# ===========================================

# Backend API URL (required)
# Local development: http://localhost:5004/api
# Production: https://your-api.onrender.com/api
VITE_API_URL=http://localhost:5004/api

# Supabase Configuration (for client-side auth/storage)
VITE_SUPABASE_URL=https://[PROJECT].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Update VITE_API_URL for your environment
# 3. DO NOT commit .env to version control
# ===========================================
