# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# ===========================================

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Port (Render will auto-assign this)
PORT=5000

# JWT Secret (use a strong random string in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Environment Mode
NODE_ENV=production

# CORS Origins (comma-separated, no spaces around commas)
# Add your InfinityFree domain here
CORS_ORIGINS=https://yourdomain.infinityfree.com,https://yourdomain.epizy.com,http://localhost:5173

# Optional: Gemini API Key (if using AI features)
GEMINI_API_KEY=your_gemini_api_key_here
